###run repeatmasker using the medusozoa library as input

#!/bin/bash

#SBATCH --job-name= ...          
#SBATCH --mail-user= ... 
#SBATCH --mail-type=ALL         
#SBATCH --partition= ...     
#SBATCH --time=5-01:02:00                  
#SBATCH --ntasks=1                         
#SBATCH --cpus-per-task=2                  
#SBATCH --mem=50G                          
#SBATCH --qos= ...            
#SBATCH --account= ...     
#SBATCH --output=medusozoa_repeatmasker_species.out                 

#sets language and character settings for the output files
export LC_ALL='C'

#load the module
module load repeatmodeler

#run repeatmasker, -lib specifies the library you want to use, -pa is the number of threads (power) you want to use, then put the genome fasta file, -a says you want it to do alignment analysis (needed for calcdiv)
RepeatMasker -lib PATH/TO/FILE/2medusozoa_rep_lib_C.fasta -pa 16 species_name.fna -a


